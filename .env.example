# --- Local Docker (docker compose up -d) ---
DATABASE_URL=postgresql://app:app@localhost:5432/assemble
DIRECT_URL=postgresql://app:app@localhost:5432/assemble

# --- Neon production (see docs/NEON.md) — quote URLs if they contain & ---
# DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://neondb_owner:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# internal = Play A (supplier delivery). client = Play B (authority-owned assurance).
DEPLOYMENT_MODE=internal
NEXT_PUBLIC_DEPLOYMENT_MODE=internal

# NextAuth v4 reads NEXTAUTH_*; AUTH_* aliases are mapped in lib/auth-env.ts
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=
AUTH_URL=http://localhost:3000
# Microsoft Entra ID (optional SSO) — register app at https://entra.microsoft.com
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=
# Or set full issuer URL instead of tenant id:
AUTH_MICROSOFT_ENTRA_ID_ISSUER=
# Show Microsoft sign-in button on /sign-in when Entra app is registered:
NEXT_PUBLIC_ENTRA_ENABLED=false
