# --- Local Docker (docker compose up -d) ---
DATABASE_URL=postgresql://app:app@localhost:5432/assemble
DIRECT_URL=postgresql://app:app@localhost:5432/assemble

# --- Supabase (see docs/SUPABASE.md) ---
# DATABASE_URL=postgresql://postgres.[ref]:[password]@....pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.[ref]:[password]@....pooler.supabase.com:5432/postgres
# NextAuth v4 reads NEXTAUTH_*; AUTH_* aliases are mapped in lib/auth-env.ts
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=
