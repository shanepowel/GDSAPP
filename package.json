{
  "name": "assemble",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "sh scripts/prisma-env.sh migrate deploy && sh scripts/prisma-env.sh generate && next build",
    "postinstall": "sh scripts/prisma-env.sh generate",
    "start": "next start",
    "db:migrate": "sh scripts/prisma-env.sh migrate dev",
    "db:deploy": "sh scripts/prisma-env.sh migrate deploy",
    "db:provision": "sh scripts/provision-db.sh",
    "ingest": "tsx scripts/ingest-ddat.ts",
    "seed:standards": "tsx scripts/seed-standards.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "ensure:demo": "tsx scripts/ensure-demo.ts",
    "seed": "npm run ingest && npm run seed:standards && npm run seed:demo",
    "db:seed-all": "npm run db:deploy && npm run seed",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.0",
    "@tanstack/react-query": "^5.90.11",
    "@trpc/client": "^11.7.2",
    "@trpc/next": "^11.7.2",
    "@trpc/react-query": "^11.7.2",
    "@trpc/server": "^11.7.2",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.1.0",
    "lucide-react": "^0.554.0",
    "next": "16.2.6",
    "next-auth": "^4.24.13",
    "next-intl": "^4.5.5",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.66.1",
    "recharts": "^3.5.0",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.6.2",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.0.14"
  }
}
