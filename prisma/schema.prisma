datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model RoleGroup {
  id    String @id
  name  String
  roles Role[]
}

model Role {
  id          String      @id
  name        String
  description String      @db.Text
  groupId     String
  group       RoleGroup   @relation(fields: [groupId], references: [id])
  levels      RoleLevel[]
}

model RoleLevel {
  id            String           @id
  name          String
  description   String           @db.Text
  roleType      String?
  seniorityRank Int              @default(0)
  roleId        String
  role          Role             @relation(fields: [roleId], references: [id])
  skills        RoleLevelSkill[]
}

model Skill {
  id           String           @id
  name         String
  description  String           @db.Text
  awareness    String?          @db.Text
  working      String?          @db.Text
  practitioner String?          @db.Text
  expert       String?          @db.Text
  isCustom     Boolean          @default(false)
  roleLevels   RoleLevelSkill[]
}

model RoleLevelSkill {
  roleLevelId   String
  skillId       String
  requiredLevel String
  roleLevel     RoleLevel @relation(fields: [roleLevelId], references: [id])
  skill         Skill     @relation(fields: [skillId], references: [id])

  @@id([roleLevelId, skillId])
}

model Standard {
  id           String         @id
  name         String
  jurisdiction String
  points       StandardPoint[]
}

model StandardPoint {
  id                String                  @id
  standardId        String
  number            Int
  title             String
  category          String?
  description       String                  @db.Text
  evidenceTypes     String[]
  phaseEmphasis     String[]
  compositionDriven Boolean                 @default(false)
  statutoryNote     String?                 @db.Text
  standard          Standard                @relation(fields: [standardId], references: [id])
  roleDeps          StandardPointRoleDep[]
  skillDeps         StandardPointSkillDep[]
  evidenceLinks     EvidenceLink[]
  questionPointRefs QuestionPointRef[]
}

model StandardPointRoleDep {
  id               String        @id @default(cuid())
  pointId          String
  roleId           String
  weight           Float         @default(1)
  minSeniorityRank Int           @default(0)
  point            StandardPoint @relation(fields: [pointId], references: [id])
}

model StandardPointSkillDep {
  id       String        @id @default(cuid())
  pointId  String
  skillId  String
  minLevel String
  weight   Float         @default(1)
  point    StandardPoint @relation(fields: [pointId], references: [id])
}

model FrameworkVersion {
  id           String      @id @default(cuid())
  source       String
  versionLabel String
  importedAt   DateTime    @default(now())
  notes        String?     @db.Text
  judgements   Judgement[]
}

model Organisation {
  id              String       @id @default(cuid())
  name            String
  /// Must match instance DEPLOYMENT_MODE (internal = Play A, client = Play B firewall).
  deploymentMode  String       @default("internal")
  users           User[]
  engagements     Engagement[]
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  name               String?
  role               String              @default("member")
  orgId              String
  org                Organisation        @relation(fields: [orgId], references: [id])
  passwordHash       String?
  reviewAssignments  ReviewAssignment[]
}

model Engagement {
  id           String        @id @default(cuid())
  name         String
  standardId   String
  /// Supplier or delivery partner label (Play B portfolio grouping)
  supplierTag  String?
  /// Framework lot or workstream (Play B portfolio grouping)
  lotTag       String?
  orgId        String
  org          Organisation  @relation(fields: [orgId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  requirements Requirement[]
  people       Person[]
  tenders      Tender[]
  evidence     Evidence[]
  shareLinks   ShareLink[]
  judgements      Judgement[]
  reviewRequests  ReviewRequest[]
}

model Requirement {
  id           String             @id @default(cuid())
  engagementId String
  title        String
  phase        String
  outcome      String             @db.Text
  channels     String[]
  sensitivity  String
  engagement   Engagement         @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  roles        RequirementRole[]
  assignments  Assignment[]
  runs         AnalysisRun[]
  constraints  Constraint[]
  rigour       RigourAssessment[]
  outcomes     Outcome[]
}

model RequirementRole {
  id            String      @id @default(cuid())
  requirementId String
  roleLevelId   String
  weight        Float       @default(1)
  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
}

model Person {
  id           String               @id @default(cuid())
  engagementId String
  displayName  String
  pseudonym    String?
  isVacancy    Boolean              @default(false)
  engagement   Engagement           @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  skills       PersonSkill[]
  assignments  Assignment[]
  availability PersonAvailability[]
}

model PersonSkill {
  id       String @id @default(cuid())
  personId String
  skillId  String
  level    String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)
}

model PersonAvailability {
  id             String    @id @default(cuid())
  personId       String
  availableFrom  DateTime?
  daysPerWeek    Float     @default(5)
  dayRate        Float?
  person         Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
}

model Assignment {
  id            String      @id @default(cuid())
  requirementId String
  personId      String
  roleLevelId   String
  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  person        Person      @relation(fields: [personId], references: [id], onDelete: Cascade)
}

model Constraint {
  id                 String      @id @default(cuid())
  requirementId      String
  budgetCap          Float?
  startBy            DateTime?
  endBy              DateTime?
  internalRatePerDay Float?
  partnerRatePerDay  Float?
  requirement        Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
}

model AnalysisRun {
  id               String      @id @default(cuid())
  requirementId    String
  createdAt        DateTime    @default(now())
  overallReadiness Float
  readinessBand    String
  result           Json
  requirement      Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
}

model Evidence {
  id           String         @id @default(cuid())
  engagementId String
  title        String
  type         String
  description  String?        @db.Text
  url          String?
  strength     String
  createdAt    DateTime       @default(now())
  engagement   Engagement     @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  links        EvidenceLink[]
}

model EvidenceLink {
  id          String         @id @default(cuid())
  evidenceId  String
  pointId     String?
  questionId  String?
  roleLevelId String?
  evidence    Evidence       @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  point       StandardPoint? @relation(fields: [pointId], references: [id])
  question    ScoredQuestion? @relation(fields: [questionId], references: [id])
}

model RigourAssessment {
  id            String                 @id @default(cuid())
  requirementId String
  createdAt     DateTime               @default(now())
  assessedBy    String?
  requirement   Requirement            @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  dimensions    RigourDimensionScore[]
}

model RigourDimensionScore {
  id           String           @id @default(cuid())
  assessmentId String
  dimension    String
  score        Int
  evidenceNote String?          @db.Text
  assessment   RigourAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model Tender {
  id              String           @id @default(cuid())
  engagementId    String
  title           String
  buyer           String
  route           String?
  qualityWeight   Float
  priceWeight     Float
  scoringScaleMax Int              @default(5)
  engagement      Engagement       @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  questions       ScoredQuestion[]
}

model ScoredQuestion {
  id             String             @id @default(cuid())
  tenderId       String
  ref            String
  text           String             @db.Text
  weight         Float
  passThreshold  Int?
  isPassFail     Boolean            @default(false)
  category       String?
  tender         Tender             @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  roleDeps       QuestionRoleDep[]
  skillDeps      QuestionSkillDep[]
  pointRefs      QuestionPointRef[]
  drafts         QuestionDraft[]
  evidenceLinks  EvidenceLink[]
}

model QuestionRoleDep {
  id               String         @id @default(cuid())
  questionId       String
  roleId           String
  weight           Float          @default(1)
  minSeniorityRank Int            @default(0)
  question         ScoredQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QuestionSkillDep {
  id         String         @id @default(cuid())
  questionId String
  skillId    String
  minLevel   String
  weight     Float          @default(1)
  question   ScoredQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QuestionPointRef {
  id         String         @id @default(cuid())
  questionId String
  pointId    String
  question   ScoredQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  point      StandardPoint  @relation(fields: [pointId], references: [id])
}

model QuestionDraft {
  id         String         @id @default(cuid())
  questionId String
  body       String         @db.Text
  createdAt  DateTime       @default(now())
  approvedBy String?
  isScaffold Boolean        @default(false)
  question   ScoredQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Outcome {
  id            String      @id @default(cuid())
  requirementId String
  event         String
  result        String
  phase         String?
  recordedAt    DateTime    @default(now())
  notes         String?     @db.Text
  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
}

model Judgement {
  id                  String            @id @default(cuid())
  subjectType         String
  subjectId           String
  engagementId        String
  status              String
  score               Float?
  frameworkVersionId  String?
  decidedBy           String?
  decidedAt           DateTime          @default(now())
  overrideReason      String?           @db.Text
  previousJudgementId String?
  engagement          Engagement        @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  frameworkVersion    FrameworkVersion? @relation(fields: [frameworkVersionId], references: [id])
}

model ReviewRequest {
  id           String             @id @default(cuid())
  engagementId String
  title        String
  subjectType  String
  subjectId    String
  status       String             @default("open")
  minApprovals Int                @default(2)
  createdById  String?
  createdAt    DateTime           @default(now())
  engagement   Engagement         @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  assignments  ReviewAssignment[]
}

model ReviewAssignment {
  id              String        @id @default(cuid())
  reviewRequestId String
  reviewerUserId  String
  stepOrder       Int           @default(0)
  status          String        @default("pending")
  comment         String?       @db.Text
  decidedAt       DateTime?
  reviewRequest   ReviewRequest @relation(fields: [reviewRequestId], references: [id], onDelete: Cascade)
  reviewer        User          @relation(fields: [reviewerUserId], references: [id])
}

model ShareLink {
  id           String     @id @default(cuid())
  engagementId String
  token        String     @unique
  expiresAt    DateTime
  createdAt    DateTime   @default(now())
  engagement   Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
}
